# ── Required ────────────────────────────────────────────────────────────────
# MongoDB connection string (local: mongodb://127.0.0.1/your-db-name)
DATABASE_URL=
# Long random string used to sign Payload auth tokens
PAYLOAD_SECRET=

# ── Email (optional — Resend) ───────────────────────────────────────────────
# Without a key, Payload logs emails to the console and the contact form
# skips its notification email (submissions are still saved).
RESEND_API_KEY=
# Address/name Payload's own emails (password resets etc.) are sent from
EMAIL_FROM_ADDRESS=onboarding@resend.dev
EMAIL_FROM_NAME=
# Contact-form notification: sent from → to
CONTACT_FROM_EMAIL=Website <onboarding@resend.dev>
CONTACT_TO_EMAIL=

# ── Media storage (optional — Cloudflare R2 / any S3-compatible bucket) ────
# Leave all of these blank to store uploads on the local filesystem instead.
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Either the account id (builds the endpoint for you) or a full endpoint URL
R2_ACCOUNT_ID=
R2_ENDPOINT=
# Public bucket/CDN URL — when set, files are served straight from R2 instead
# of being proxied through the app
R2_PUBLIC_URL=
